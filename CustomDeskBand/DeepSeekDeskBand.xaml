<cs:CSDeskBandWpf x:Class="CustomDeskBand.DeepSeekDeskBand"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:cs="clr-namespace:CSDeskBand.Wpf;assembly=CSDeskBand.Wpf"
                  Height="40"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">

    <Grid x:Name="RootGrid"
          ToolTip="加载中..."
          VerticalAlignment="Center"
          Margin="0,0,4,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <!-- 余额行 -->
        <TextBlock x:Name="BalanceSymbol"
                   Grid.Row="0"
                   Grid.Column="0"
                   Foreground="White"
                   FontFamily="Segoe UI, Microsoft YaHei"
                   FontWeight="Regular"
                   FontSize="{x:Static SystemFonts.StatusFontSize}"
                   HorizontalAlignment="Right"
                   Text="¥ " />
        <TextBlock x:Name="BalanceLabel"
                   Grid.Row="0"
                   Grid.Column="1"
                   Foreground="White"
                   FontFamily="Segoe UI, Microsoft YaHei"
                   FontWeight="Regular"
                   FontSize="{x:Static SystemFonts.StatusFontSize}"
                   HorizontalAlignment="Right" />

        <!-- 消耗行 -->
        <TextBlock x:Name="ConsumedSymbol"
                   Grid.Row="1"
                   Grid.Column="0"
                   Foreground="White"
                   FontFamily="Segoe UI, Microsoft YaHei"
                   FontWeight="Regular"
                   FontSize="{x:Static SystemFonts.StatusFontSize}"
                   HorizontalAlignment="Right"
                   Text="- " />
        <TextBlock x:Name="ConsumedLabel"
                   Grid.Row="1"
                   Grid.Column="1"
                   Foreground="White"
                   FontFamily="Segoe UI, Microsoft YaHei"
                   FontWeight="Regular"
                   FontSize="{x:Static SystemFonts.StatusFontSize}"
                   HorizontalAlignment="Right" />
    </Grid>

</cs:CSDeskBandWpf>
