<cs:CSDeskBandWpf x:Class="CustomDeskBand.BatteryDeskBand"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:cs="clr-namespace:CSDeskBand.Wpf;assembly=CSDeskBand.Wpf"
                  Height="40"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">

    <Grid x:Name="RootGrid"
          Background="Transparent"
          ToolTip="电池电量"
          VerticalAlignment="Center"
          Margin="4,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- 电池图标（高12px偶数，便于在40px任务栏中垂直居中） -->
        <Canvas x:Name="BatteryCanvas"
                Grid.Column="0"
                Width="24"
                Height="12"
                Margin="0,0,4,0">
            <!-- 电池外壳 -->
            <Rectangle x:Name="BatteryBody"
                       Width="21"
                       Height="12"
                       RadiusX="2"
                       RadiusY="2"
                       Stroke="White"
                       StrokeThickness="1"
                       Fill="Transparent" />
            <!-- 电池正极触点 -->
            <Rectangle x:Name="BatteryCap"
                       Canvas.Left="21"
                       Canvas.Top="3"
                       Width="3"
                       Height="6"
                       RadiusX="1"
                       RadiusY="1"
                       Fill="White" />
            <!-- 电量填充 -->
            <Rectangle x:Name="BatteryFill"
                       Canvas.Left="2"
                       Canvas.Top="2"
                       Height="8"
                       RadiusX="1"
                       RadiusY="1"
                       Fill="White" />
        </Canvas>

        <!-- 百分比（字体在代码中设为偶数，便于水平居中） -->
        <TextBlock x:Name="PercentLabel"
                   Grid.Column="1"
                   Foreground="White"
                   FontFamily="Segoe UI, Microsoft YaHei"
                   FontWeight="Regular"
                   VerticalAlignment="Center"
                   Text="--%" />
    </Grid>

</cs:CSDeskBandWpf>
